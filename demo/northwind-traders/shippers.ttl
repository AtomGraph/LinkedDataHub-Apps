  @prefix dh:     <https://www.w3.org/ns/ldt/document-hierarchy#> .
  @prefix ldh:    <https://w3id.org/atomgraph/linkeddatahub#> .
  @prefix dct:    <http://purl.org/dc/terms/> .
  @prefix sp:     <http://spinrdf.org/sp#> .
  @prefix spin:   <http://spinrdf.org/spin#> .
  @prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
  @prefix sioc:   <http://rdfs.org/sioc/ns#> .

  # Main container document
  <> a dh:Container ;
      dct:title "Shippers" ;
      rdf:_1 <#select-shippers> .

  # Object block (references the view)
  <#select-shippers> a ldh:Object ;
      rdf:value <#select-shippers-view> .

  # View block (references the query, no mode specified - uses default)
  <#select-shippers-view> a ldh:View ;
      spin:query <#select-shippers-query> .

  # SELECT query
  <#select-shippers-query> a sp:Select ;
      dct:title "Select shippers" ;
      sp:text """PREFIX  schema: <https://schema.org/>

  SELECT DISTINCT  ?shipper
  WHERE
    { GRAPH ?doc
        { ?shipper  a                 schema:Corporation ;
                    schema:legalName  ?companyName
          GRAPH ?orderDeliveryDoc
            { ?orderDelivery
                        a                schema:ParcelDelivery ;
                        schema:provider  ?shipper
            }
        }
    }
  ORDER BY ?companyName""" .
