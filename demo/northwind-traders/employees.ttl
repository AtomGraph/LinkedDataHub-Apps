  @prefix dh:     <https://www.w3.org/ns/ldt/document-hierarchy#> .
  @prefix ldh:    <https://w3id.org/atomgraph/linkeddatahub#> .
  @prefix dct:    <http://purl.org/dc/terms/> .
  @prefix sp:     <http://spinrdf.org/sp#> .
  @prefix spin:   <http://spinrdf.org/spin#> .
  @prefix ac:     <https://w3id.org/atomgraph/client#> .
  @prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

  # Main container document
  <> a dh:Container ;
      dct:title "Employees" ;
      rdf:_1 <#employee-intro> ;
      rdf:_2 <#sales-by-employee> ;
      rdf:_3 <#select-employees> .

  # Intro XHTML
  <#employee-intro> a ldh:XHTML ;
      rdf:value """<div xmlns="http://www.w3.org/1999/xhtml">
          <h3>Employee Performance</h3>
          <p>Track employee sales performance and order processing metrics. Understanding individual
             contributions helps recognize top performers, identify coaching opportunities, and optimize territory assignments.</p>
      </div>"""^^rdf:XMLLiteral .

  # Sales by employee chart
  <#sales-by-employee> a ldh:ResultSetChart ;
      dct:title "Sales by employee" ;
      spin:query <#sales-by-employee-query> ;
      ldh:chartType <https://w3id.org/atomgraph/client#BarChart> ;
      ldh:categoryVarName "employeeName" ;
      ldh:seriesVarName "totalSales" .

  <#sales-by-employee-query> a sp:Select ;
      dct:title "Sales by employee" ;
      sp:text """PREFIX schema: <https://schema.org/>

SELECT ?employeeName (SUM(?sale) AS ?totalSales)
WHERE {
    GRAPH ?orderGraph {
        ?order schema:broker ?employee ;
               schema:orderedItem ?orderItem .
        ?orderItem schema:orderQuantity ?quantity ;
                   schema:price ?price .
        BIND(?quantity * ?price AS ?sale)
    }
    GRAPH ?employeeGraph {
        ?employee schema:givenName ?givenName ;
                  schema:familyName ?familyName .
        BIND(CONCAT(?givenName, " ", ?familyName) AS ?employeeName)
    }
}
GROUP BY ?employee ?employeeName
ORDER BY DESC(?totalSales)""" .

  # Object block (references the view)
  <#select-employees> a ldh:Object ;
      rdf:value <#select-employees-view> .

  # View block (references the query, uses GridMode)
  <#select-employees-view> a ldh:View ;
      spin:query <#select-employees-query> ;
      ac:mode <https://w3id.org/atomgraph/client#GridMode> .

  # SELECT query
  <#select-employees-query> a sp:Select ;
      dct:title "Select employees" ;
      sp:text """PREFIX  schema: <https://schema.org/>

  SELECT DISTINCT  ?employee
  WHERE
    { GRAPH ?doc
        { ?employee  a                 schema:Person ;
                    schema:familyName  ?lastName
          OPTIONAL
            { ?employee  schema:areaServed  ?territory }
          OPTIONAL
            { ?employee  schema:sponsor  ?reportsToEmployee }
          FILTER NOT EXISTS { GRAPH ?supplierGraph
                                { ?supplier  a               schema:Corporation ;
                                            schema:employee  ?employee
                                }
                            }
        }
    }
  ORDER BY ?lastName""" .
